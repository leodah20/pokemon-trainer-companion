# Copy this file to .env and fill in real values. .env itself is gitignored.

DATABASE_URL="postgresql://user:password@localhost:5432/pokemon_trainer_companion?schema=public"

# Get a free key at https://aistudio.google.com/apikey — Gemini Flash/Flash-Lite free tier
# (1,500 requests/day, no credit card) is what the Companion AI endpoint is built against.
# Leave empty to disable /api/companion — it returns 503 instead of crashing.
GEMINI_API_KEY=
